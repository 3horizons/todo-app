# ──────────────────────────────────────────────────────────────────────────────
# Terraform Variables — Staging Environment
# Generated by Three Horizons Golden Path Template
# ──────────────────────────────────────────────────────────────────────────────

# General
environment         = "${{ values.environment }}"
location            = "${{ values.azure_region }}"
resource_group_name = "${{ values.name }}-rg"
project_name        = "${{ values.name }}"
frontend_location   = "${{ values.azure_region }}"

# PostgreSQL — Staging sizing (GP_Standard_D2s_v3)
postgres_sku_name       = "GP_Standard_D2s_v3"
postgres_storage_mb     = 65536
postgres_version        = "16"
postgres_admin_username = "psqladmin"

# Redis — Staging sizing (Standard C1)
redis_sku_name = "Standard"
redis_family   = "C"
redis_capacity = 1

# App Service — Staging sizing (S1)
app_service_sku_name = "S1"

# Container Image
docker_registry_url = "ghcr.io"
docker_image_name   = "${{ values.orgName }}/${{ values.repoName }}"
docker_image_tag    = "latest"

# Monitoring
log_analytics_retention_days = 60

# Alerts
alert_email = "devops@${{ values.orgName }}.com"

# Tags
tags = {
  environment = "staging"
  project     = "${{ values.name }}"
  owner       = "${{ values.owner }}"
  managed-by  = "terraform"
  golden-path = "todo-app"
  system      = "${{ values.system }}"
}
