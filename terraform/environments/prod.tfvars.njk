# ──────────────────────────────────────────────────────────────────────────────
# Terraform Variables — Production Environment
# Generated by Three Horizons Golden Path Template
# ──────────────────────────────────────────────────────────────────────────────

# General
environment         = "${{ values.environment }}"
location            = "${{ values.azure_region }}"
resource_group_name = "${{ values.name }}-rg"
project_name        = "${{ values.name }}"
frontend_location   = "${{ values.azure_region }}"

# PostgreSQL — Production sizing (GP_Standard_D4s_v3)
postgres_sku_name       = "GP_Standard_D4s_v3"
postgres_storage_mb     = 131072
postgres_version        = "16"
postgres_admin_username = "psqladmin"

# Redis — Production sizing (Standard C2)
redis_sku_name = "Standard"
redis_family   = "C"
redis_capacity = 2

# App Service — Production sizing (P1v3)
app_service_sku_name = "P1v3"

# Container Image
docker_registry_url = "ghcr.io"
docker_image_name   = "${{ values.orgName }}/${{ values.repoName }}"
docker_image_tag    = "latest"

# Monitoring
log_analytics_retention_days = 90

# Alerts
alert_email = "devops@${{ values.orgName }}.com"

# Tags
tags = {
  environment = "prod"
  project     = "${{ values.name }}"
  owner       = "${{ values.owner }}"
  managed-by  = "terraform"
  golden-path = "todo-app"
  system      = "${{ values.system }}"
}
